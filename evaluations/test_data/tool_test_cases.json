  "crm_test_cases": [
    {
      "id": "crm_01",
      "action": "create",
      "input": {"name": "Test Client Alpha", "cnic": "12345-1234567-1", "contact": "0300-1111111", "case_type": "Murder", "charges": "PPC 302", "bail_status": "in custody"},
      "expected_success": true
    },
    {
      "id": "crm_02",
      "action": "get",
      "input": {"client_id": "_dynamic_"},
      "expected_success": true,
      "expected_fields": ["name", "cnic", "contact", "case_type"]
    },
    {
      "id": "crm_03",
      "action": "update",
      "input": {"client_id": "_dynamic_", "field": "bail_status", "value": "on bail"},
      "expected_success": true
    },
    {
      "id": "crm_04",
      "action": "search",
      "input": {"query": "Test Client Alpha"},
      "expected_success": true
    },
    {
      "id": "crm_05",
      "action": "update",
      "input": {"client_id": "_dynamic_", "field": "invalid_field", "value": "test"},
      "expected_success": false
    },
    {
      "id": "crm_06",
      "action": "get",
      "input": {"client_id": "nonexistent_id_xyz"},
      "expected_success": false
    },
    {
      "id": "crm_07",
      "action": "delete",
      "input": {"client_id": "_dynamic_"},
      "expected_success": true
    }
  ],
