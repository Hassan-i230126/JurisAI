# ═══════════════════════════════════════════════════════════════
# Juris AI — Environment Configuration
# Copy to .env and modify as needed
# ═══════════════════════════════════════════════════════════════

# ─── Ollama ───────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=phi4-mini
EMBEDDING_MODEL=bge-m3

# ─── ChromaDB ─────────────────────────────────────────────────
# CHROMA_PERSIST_DIR=./data/chroma_db
# CHROMA_COLLECTION_NAME=juris_legal_corpus

# ─── SQLite ───────────────────────────────────────────────────
# SQLITE_DB_PATH=./data/juris.db

# ─── RAG Tuning ───────────────────────────────────────────────
RAG_TOP_K=3
RAG_DISTANCE_THRESHOLD=1.4
CHUNK_SIZE=350
CHUNK_OVERLAP=50

# ─── LLM Generation ──────────────────────────────────────────
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024
LLM_NUM_CTX=3072
LLM_NUM_THREADS=8

# ─── Conversation ────────────────────────────────────────────
MAX_HISTORY_TURNS=4

# ─── Cache ────────────────────────────────────────────────────
EMBEDDING_CACHE_SIZE=200

# ─── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── Server ───────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ─── Indexing ─────────────────────────────────────────────────
INDEXING_BATCH_SIZE=4
EMBEDDING_BATCH_SIZE=32
JUDGMENT_BATCH_SIZE=50
MAX_JUDGMENT_CHARS=3000
